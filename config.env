# Default project configuration.
# install.sh writes the deployed runtime configuration to RUNTIME_CONFIG_FILE.

PROJECT_NAME="trojan-go-sni"
PROJECT_DISPLAY_NAME="Trojan-Go SNI"

TROJAN_DOMAIN=""
TROJAN_PORT="8080"
TROJAN_PASSWORD=""
TROJAN_REMOTE_ADDR="127.0.0.1"
TROJAN_REMOTE_PORT="8081"

WEB_DOMAIN=""
WEB_PORT="8443"
ENABLE_IPV6="N"

CERTBOT_EMAIL=""
LE_STAGING="0"
SKIP_DNS_CHECK="0"

TROJAN_GO_REPO="p4gefau1t/trojan-go"
TROJAN_BIN="/usr/local/bin/trojan-go"
TROJAN_CLI_LINK="/usr/local/bin/trojan"

INSTALL_ROOT="/opt/trojan-go-sni"
RUNTIME_DIR="/etc/trojan-go-sni"
RUNTIME_CONFIG_FILE="/etc/trojan-go-sni/config.env"

TROJAN_CONFIG_DIR="/etc/trojan-go"
TROJAN_CONFIG_FILE="/etc/trojan-go/config.json"
TROJAN_SERVICE_FILE="/etc/systemd/system/trojan-go.service"

WEB_ROOT="/var/www/trojan-go-sni"

NGINX_HTTP_CONF="/etc/nginx/conf.d/trojan-go-sni.conf"
NGINX_STREAM_CONF_DIR="/etc/nginx/stream-conf.d"
NGINX_STREAM_CONF="/etc/nginx/stream-conf.d/trojan-go-sni.conf"
NGINX_MAIN_CONF="/etc/nginx/nginx.conf"

RENEW_SERVICE_FILE="/etc/systemd/system/trojan-go-sni-renew.service"
RENEW_TIMER_FILE="/etc/systemd/system/trojan-go-sni-renew.timer"
RENEW_TIMER_CALENDAR="daily"
RENEW_RANDOM_DELAY="2h"
RENEW_BEFORE_DAYS="7"

LOG_DIR="/var/log/trojan-go-sni"
LOGROTATE_FILE="/etc/logrotate.d/trojan-go-sni"
BACKUP_ROOT="/var/backups/trojan-go-sni"

CLIENT_NAME=""
CLIENT_URI_FILE="/etc/trojan-go-sni/client.uri"
CLIENT_QR_PNG="/etc/trojan-go-sni/client-qr.png"
CLIENT_QR_TXT="/etc/trojan-go-sni/client-qr.txt"

NON_INTERACTIVE="0"
ASSUME_YES="0"
